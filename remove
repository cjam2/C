def find_last_user_index(messages):
    for i in range(len(messages) - 1, -1, -1):
        if messages[i]["role"] == "user":
            return i
    return None

def delete_messages_after(messages, idx):
    # keep messages up to idx (inclusive)
    del messages[idx+1:]







st.markdown("### Edit last question")

last_user_idx = find_last_user_index(st.session_state.messages)

if last_user_idx is None:
    st.caption("No questions yet.")
else:
    last_q = st.session_state.messages[last_user_idx]["content"]
    edited_q = st.text_area("Last question", value=last_q, key="edit_last_question")

    c1, c2 = st.columns(2)
    with c1:
        if st.button("Update & Regenerate"):
            # Replace last user message
            st.session_state.messages[last_user_idx]["content"] = edited_q

            # Delete everything after that question (old assistant reply etc.)
            delete_messages_after(st.session_state.messages, last_user_idx)

            # Mark that we should re-run an answer for this edited question
            st.session_state.pending_question = edited_q
            st.rerun()

    with c2:
        if st.button("Cancel edit"):
            st.session_state.edit_last_question = last_q



if "active_page_ids" not in st.session_state:
    st.session_state.active_page_ids = None  # None means global search

if "pending_question" not in st.session_state:
    st.session_state.pending_question = None








