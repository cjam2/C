def filter_chunks_by_page_ids(chunks_meta, page_ids_set):
    if not page_ids_set:
        return chunks_meta
    return [c for c in chunks_meta if c.get("page_id") in page_ids_set]





# Pick the page_ids from top results (unique)
new_scope = []
seen = set()
for r in retrieved[:20]:
    pid = r.get("page_id")
    if pid and pid not in seen:
        seen.add(pid)
        new_scope.append(pid)
    if len(new_scope) >= 8:
        break

# Update scope only if in follow-up mode
if scope_mode.startswith("Follow-up"):
    st.session_state.active_page_ids = set(new_scope)





chunks_for_search = st.session_state.chunks_meta
if scope_mode.startswith("Follow-up") and st.session_state.active_page_ids:
    chunks_for_search = filter_chunks_by_page_ids(chunks_for_search, st.session_state.active_page_ids)

# Build a BM25 for scoped chunks (fast enough for small scope)
