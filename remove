import re
from collections import defaultdict

def classify_question(q: str) -> str:
    """
    Cheap rule-based classification. Improves response style without an LLM.
    """
    s = q.strip().lower()
    if any(s.startswith(x) for x in ["how do i", "how to", "how can", "steps", "procedure", "setup", "configure", "install"]):
        return "howto"
    if any(s.startswith(x) for x in ["why", "root cause", "reason", "because"]):
        return "why"
    if any(s.startswith(x) for x in ["what is", "what are", "define", "meaning", "explain"]):
        return "definition"
    if any(s.startswith(x) for x in ["where", "which page", "which doc", "link", "url"]):
        return "where"
    if any(s.startswith(x) for x in ["when", "date", "timeline", "deadline"]):
        return "when"
    if any(x in s for x in ["error", "failed", "failure", "exception", "stack trace", "429", "401", "timeout"]):
        return "troubleshoot"
    return "general"


def split_sentences(text: str):
    """
    Simple sentence splitter (no nltk). Good enough for docs.
    """
    if not text:
        return []
    text = re.sub(r"\s+", " ", text).strip()
    parts = re.split(r"(?<=[.!?])\s+(?=[A-Z0-9\[])", text)
    return [p.strip() for p in parts if p.strip()]


def score_overlap(query_tokens, sent_tokens):
    """
    Lexical overlap score normalized by query size.
    """
    if not sent_tokens:
        return 0.0
    q = set(query_tokens)
    s = set(sent_tokens)
    ov = len(q & s)
    if ov == 0:
        return 0.0
    return ov / max(1, len(q))


def highlight_keywords(text: str, query: str):
    """
    Highlights query tokens using <mark>. Streamlit can render unsafe HTML if enabled.
    We'll keep it safe-ish by escaping only minimal and not injecting user HTML.
    """
    if not text:
        return ""
    tokens = [t for t in tokenize(query) if len(t) >= 3]
    if not tokens:
        return text

    # Unique + longer first to avoid partial overlaps
    tokens = sorted(set(tokens), key=len, reverse=True)

    def repl(match):
        return f"<mark>{match.group(0)}</mark>"

    out = text
    for tok in tokens[:12]:
        out = re.sub(rf"(?i)\b{re.escape(tok)}\b", repl, out)
    return out


def fuse_sentences(candidates, max_groups=5, max_sentences_per_group=3):
    """
    Sentence fusion:
    - groups sentences by (url, title)
    - picks top ones and merges into short coherent bullets per page
    """
    by_page = defaultdict(list)
    for c in candidates:
        key = (c.get("url", ""), c.get("title", ""))
        by_page[key].append(c)

    fused = []
    for (url, title), sents in by_page.items():
        sents.sort(key=lambda x: x["score"], reverse=True)
        chosen = sents[: max_sentences_per_group]

        # Deduplicate very similar starts
        seen = set()
        cleaned = []
        for x in chosen:
            k = x["sentence"][:80]
            if k in seen:
                continue
            seen.add(k)
            cleaned.append(x["sentence"])

        if cleaned:
            fused.append({
                "title": title,
                "url": url,
                "score": sents[0]["score"],
                "text": " ".join(cleaned)
            })

    fused.sort(key=lambda x: x["score"], reverse=True)
    return fused[:max_groups]


def extract_top_sentences_from_chunks(query: str, retrieved_chunks: list, max_candidates=60):
    """
    Build a pool of candidate sentences from top chunks.
    """
    q_tokens = tokenize(query)
    candidates = []
    for r in retrieved_chunks:
        chunk = r.get("chunk", "")
        for sent in split_sentences(chunk):
            stoks = tokenize(sent)
            sc = score_overlap(q_tokens, stoks)
            if sc <= 0:
                continue
            candidates.append({
                "score": sc,
                "sentence": sent,
                "title": r.get("title", ""),
                "url": r.get("url", ""),
                "space": r.get("space", ""),
                "updated": r.get("updated", "")
            })

    candidates.sort(key=lambda x: x["score"], reverse=True)
    return candidates[:max_candidates]


def page_summaries(query: str, retrieved_chunks: list, top_pages=5, sentences_per_page=2):
    """
    Page summarization (query-aware):
    - groups by page (url/title)
    - chooses best sentences per page
    """
    candidates = extract_top_sentences_from_chunks(query, retrieved_chunks, max_candidates=200)
    by_page = defaultdict(list)
    for c in candidates:
        by_page[(c.get("url", ""), c.get("title", ""))].append(c)

    summaries = []
    for (url, title), sents in by_page.items():
        sents.sort(key=lambda x: x["score"], reverse=True)
        picked = [x["sentence"] for x in sents[:sentences_per_page]]
        if picked:
            summaries.append({
                "title": title,
                "url": url,
                "score": sents[0]["score"],
                "summary": " ".join(picked)
            })

    summaries.sort(key=lambda x: x["score"], reverse=True)
    return summaries[:top_pages]





