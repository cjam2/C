def page_key(r):
    return (r.get("url", ""), r.get("title", ""))

def aggregate_by_page(retrieved_chunks):
    """
    Turn chunk-level results into page-level ranking.
    Score = sum of top chunk scores for that page (bounded).
    """
    pages = {}
    for r in retrieved_chunks:
        k = page_key(r)
        if k not in pages:
            pages[k] = {
                "url": r.get("url", ""),
                "title": r.get("title", ""),
                "space": r.get("space", ""),
                "updated": r.get("updated", ""),
                "chunks": [],
                "score": 0.0
            }
        pages[k]["chunks"].append(r)

    # compute page score using top N chunk scores (prevents one page dominating)
    for k, p in pages.items():
        scores = sorted([float(x.get("score", 0.0) or 0.0) for x in p["chunks"]], reverse=True)
        top_scores = scores[:4]  # use top 4 chunk matches
        p["score"] = sum(top_scores)
        # keep chunks sorted for later use
        p["chunks"].sort(key=lambda x: float(x.get("score", 0.0) or 0.0), reverse=True)

    ranked = sorted(pages.values(), key=lambda x: x["score"], reverse=True)
    return ranked

def best_quotes_for_page(query: str, page_obj: dict, max_quotes=3):
    """
    From the page's top chunks, pick best sentences and return a few.
    """
    cands = extract_top_sentences_from_chunks(query, page_obj["chunks"][:8], max_candidates=200)
    # pick top sentences, but dedupe
    quotes = []
    seen = set()
    for c in cands:
        s = c["sentence"]
        k = s[:90]
        if k in seen:
            continue
        seen.add(k)
        quotes.append(s)
        if len(quotes) >= max_quotes:
            break
    return quotes

def build_assistant_reply_page_first(query: str, retrieved_chunks: list):
    """
    Assistant-like response:
    - rank pages
    - show direct answer from best page quotes
    - show mini summaries for top pages
    """
    qtype = classify_question(query)
    if not retrieved_chunks:
        return "I couldn’t find matches in the indexed docs. Try different keywords or broaden the CQL."

    # 1) Page-first ranking
    ranked_pages = aggregate_by_page(retrieved_chunks)
    best_page = ranked_pages[0] if ranked_pages else None

    # 2) Direct answer from best page
    lines = []
    lines.append("**Answer (from the best-matching page):**")

    if best_page:
        quotes = best_quotes_for_page(query, best_page, max_quotes=3)
        if quotes:
            direct = " ".join(quotes[:2])
            lines.append(highlight_keywords(direct, query))
        else:
            # fallback: use top chunk excerpt
            top_chunk = best_page["chunks"][0].get("chunk", "")
            lines.append(highlight_keywords(top_chunk[:350] + "...", query))

        if best_page.get("url"):
            lines.append(f"<small>Primary source: <a href='{best_page['url']}' target='_blank'>{best_page['title']}</a></small>")

    # 3) Style: steps for how-to, bullets otherwise
    if best_page:
        if qtype == "howto":
            lines.append("\n**Suggested steps (extracted):**")
            steps = best_quotes_for_page(query, best_page, max_quotes=6)
            for i, s in enumerate(steps, 1):
                lines.append(f"{i}. {highlight_keywords(s, query)}")
        elif qtype == "troubleshoot":
            lines.append("\n**Likely causes / fixes (extracted):**")
            items = best_quotes_for_page(query, best_page, max_quotes=6)
            for s in items:
                lines.append(f"- {highlight_keywords(s, query)}")
        else:
            lines.append("\n**Key points (extracted):**")
            items = best_quotes_for_page(query, best_page, max_quotes=5)
            for s in items:
                lines.append(f"- {highlight_keywords(s, query)}")

    # 4) Top pages section (mini summaries)
    lines.append("\n**Top pages to check:**")
    for p in ranked_pages[:6]:
        quotes = best_quotes_for_page(query, p, max_quotes=2)
        summary = " ".join(quotes) if quotes else (p["chunks"][0].get("chunk", "")[:200] + "…")
        summary = highlight_keywords(summary, query)

        if p.get("url"):
            lines.append(f"- <a href='{p['url']}' target='_blank'>{p['title']}</a>: {summary}")
        else:
            lines.append(f"- {p['title']}: {summary}")

    # 5) Assistant-like follow-up
    if qtype in ("howto", "troubleshoot"):
        lines.append("\n**Quick follow-up (so I can narrow it down):**")
        lines.append("- Which environment is this for (SIT/UAT/Prod) and what’s the exact component/service name?")

    return "\n".join(lines)









