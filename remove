import re

def split_sentences(text: str):
    """
    Simple sentence splitter without nltk.
    Works decently for internal docs.
    """
    if not text:
        return []
    text = re.sub(r"\s+", " ", text).strip()
    # split on ., ?, ! followed by space/cap/number/[
    parts = re.split(r"(?<=[.!?])\s+(?=[A-Z0-9\[])", text)
    # fallback: if not splitting well, return whole text
    return [p.strip() for p in parts if p.strip()]

def score_sentence(query_tokens, sent_tokens):
    """
    Fast lexical overlap score.
    You can tune weights later.
    """
    if not sent_tokens:
        return 0.0
    q = set(query_tokens)
    s = set(sent_tokens)
    overlap = len(q & s)
    if overlap == 0:
        return 0.0
    # normalize by query size so longer queries behave
    return overlap / max(1, len(q))

def build_sentence_answers(query: str, retrieved_chunks: list, max_sentences=6):
    """
    Takes BM25 top chunks and returns best sentences with citations.
    """
    q_tokens = tokenize(query)

    candidates = []
    for r in retrieved_chunks:
        chunk = r.get("chunk", "")
        for sent in split_sentences(chunk):
            stoks = tokenize(sent)
            sc = score_sentence(q_tokens, stoks)
            if sc <= 0:
                continue
            candidates.append({
                "score": sc,
                "sentence": sent,
                "title": r.get("title", ""),
                "url": r.get("url", ""),
                "space": r.get("space", ""),
                "updated": r.get("updated", "")
            })

    # sort best-first; keep diverse-ish by not repeating identical sentences
    candidates.sort(key=lambda x: x["score"], reverse=True)

    seen = set()
    picked = []
    for c in candidates:
        key = c["sentence"][:120]
        if key in seen:
            continue
        seen.add(key)
        picked.append(c)
        if len(picked) >= max_sentences:
            break

    return picked



