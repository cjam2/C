# -----------------------------
# Cache Helpers
# -----------------------------
def save_chunks(chunks_meta):
    with open(CHUNKS_PATH, "w", encoding="utf-8") as f:
        for item in chunks_meta:
            f.write(json.dumps(item, ensure_ascii=False) + "\n")


def load_chunks():
    if not os.path.exists(CHUNKS_PATH):
        return None
    chunks = []
    with open(CHUNKS_PATH, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                chunks.append(json.loads(line))
    return chunks


# -----------------------------
# Parallel Page Processing + Token caching
# -----------------------------
def process_page_to_chunks(p, chunk_size, overlap):
    text = html_to_text(p.get("html", ""))
    chunks = chunk_words(text, chunk_size=chunk_size, overlap=overlap)

    out = []
    for c in chunks:
        out.append(
            {
                "page_id": p.get("id", ""),
                "title": p.get("title", ""),
                "space": p.get("space", ""),
                "updated": p.get("updated", ""),
                "url": p.get("url", ""),
                "chunk": c,
                "tokens": tokenize(c),
            }
        )
    return out


# -----------------------------
# Extractive assistant helpers
# -----------------------------
def classify_question(q: str) -> str:
    s = q.strip().lower()
    if any(
        s.startswith(x)
        for x in ["how do i", "how to", "how can", "steps", "procedure", "setup", "configure", "install"]
    ):
        return "howto"
    if any(s.startswith(x) for x in ["why", "root cause", "reason"]):
        return "why"
    if any(s.startswith(x) for x in ["what is", "what are", "define", "meaning", "explain"]):
        return "definition"
    if any(s.startswith(x) for x in ["where", "which page", "which doc", "link", "url"]):
        return "where"
    if any(s.startswith(x) for x in ["when", "date", "timeline", "deadline"]):
        return "when"
    if any(x in s for x in ["error", "failed", "failure", "exception", "stack trace", "429", "401", "timeout"]):
        return "troubleshoot"
    return "general"


def split_sentences(text: str):
    if not text:
        return []
    text = re.sub(r"\s+", " ", text).strip()
    parts = re.split(r"(?<=[.!?])\s+(?=[A-Z0-9\[])", text)
    return [p.strip() for p in parts if p.strip()]


def score_overlap(query_tokens, sent_tokens):
    if not sent_tokens:
        return 0.0
    q = set(query_tokens)
    s = set(sent_tokens)
    ov = len(q & s)
    if ov == 0:
        return 0.0
    return ov / max(1, len(q))


def highlight_keywords(text: str, query: str):
    if not text:
        return ""
    tokens = [t for t in tokenize(query) if len(t) >= 3]
    if not tokens:
        return text

    tokens = sorted(set(tokens), key=len, reverse=True)

    def repl(match):
        return f"<mark>{match.group(0)}</mark>"

    out = text
    for tok in tokens[:12]:
        out = re.sub(rf"(?i)\b{re.escape(tok)}\b", repl, out)
    return out


def extract_top_sentences_from_chunks(query: str, retrieved_chunks: list, max_candidates=120):
    q_tokens = tokenize(query)
    candidates = []
    for r in retrieved_chunks:
        chunk = r.get("chunk", "")
        for sent in split_sentences(chunk):
            sc = score_overlap(q_tokens, tokenize(sent))
            if sc <= 0:
                continue
            candidates.append(
                {
                    "score": sc,
                    "sentence": sent,
                    "title": r.get("title", ""),
                    "url": r.get("url", ""),
                    "page_id": r.get("page_id", ""),
                    "space": r.get("space", ""),
                    "updated": r.get("updated", ""),
                }
            )

    candidates.sort(key=lambda x: x["score"], reverse=True)
    return candidates[:max_candidates]


def page_key(r):
    return (r.get("page_id", ""), r.get("url", ""), r.get("title", ""))


def aggregate_by_page(retrieved_chunks):
    pages = {}
    for r in retrieved_chunks:
        k = page_key(r)
        if k not in pages:
            pages[k] = {
                "page_id": r.get("page_id", ""),
                "url": r.get("url", ""),
                "title": r.get("title", ""),
                "space": r.get("space", ""),
                "updated": r.get("updated", ""),
                "chunks": [],
                "score": 0.0,
            }
        pages[k]["chunks"].append(r)

    for _, p in pages.items():
        scores = sorted([float(x.get("score", 0.0) or 0.0) for x in p["chunks"]], reverse=True)
        p["score"] = sum(scores[:4])  # top-4 chunk sum
        p["chunks"].sort(key=lambda x: float(x.get("score", 0.0) or 0.0), reverse=True)

    ranked = sorted(pages.values(), key=lambda x: x["score"], reverse=True)
    return ranked


def best_quotes_for_page(query: str, page_obj: dict, max_quotes=3):
    cands = extract_top_sentences_from_chunks(query, page_obj["chunks"][:8], max_candidates=250)
    quotes = []
    seen = set()
    for c in cands:
        s = c["sentence"]
        k = s[:90]
        if k in seen:
            continue
        seen.add(k)
        quotes.append(s)
        if len(quotes) >= max_quotes:
            break
    return quotes


def build_assistant_reply_page_first(query: str, retrieved_chunks: list):
    qtype = classify_question(query)
    if not retrieved_chunks:
        return "I couldn’t find matches in the indexed docs. Try different keywords or broaden the CQL."

    ranked_pages = aggregate_by_page(retrieved_chunks)
    best_page = ranked_pages[0] if ranked_pages else None

    lines = []
    lines.append("**Answer (grounded in docs):**")

    if best_page:
        quotes = best_quotes_for_page(query, best_page, max_quotes=3)
        if quotes:
            direct = " ".join(quotes[:2])
            lines.append(highlight_keywords(direct, query))
        else:
            top_chunk = best_page["chunks"][0].get("chunk", "")
            lines.append(highlight_keywords(top_chunk[:350] + "...", query))

        if best_page.get("url"):
            lines.append(
                f"<small>Primary source: <a href='{best_page['url']}' target='_blank'>{best_page['title']}</a></small>"
            )

    if best_page:
        if qtype == "howto":
            lines.append("\n**Suggested steps (extracted):**")
            steps = best_quotes_for_page(query, best_page, max_quotes=6)
            for i, s in enumerate(steps, 1):
                lines.append(f"{i}. {highlight_keywords(s, query)}")
        elif qtype == "troubleshoot":
            lines.append("\n**Likely causes / fixes (extracted):**")
            items = best_quotes_for_page(query, best_page, max_quotes=6)
            for s in items:
                lines.append(f"- {highlight_keywords(s, query)}")
        else:
            lines.append("\n**Key points (extracted):**")
            items = best_quotes_for_page(query, best_page, max_quotes=5)
            for s in items:
                lines.append(f"- {highlight_keywords(s, query)}")

    lines.append("\n**Top pages to check:**")
    for p in ranked_pages[:6]:
        quotes = best_quotes_for_page(query, p, max_quotes=2)
        summary = " ".join(quotes) if quotes else (p["chunks"][0].get("chunk", "")[:220] + "…")
        summary = highlight_keywords(summary, query)

        if p.get("url"):
            lines.append(f"- <a href='{p['url']}' target='_blank'>{p['title']}</a>: {summary}")
        else:
            lines.append(f"- {p['title']}: {summary}")

    if qtype in ("howto", "troubleshoot"):
        lines.append("\n**Quick follow-up (to narrow it down):**")
        lines.append("- Which environment is this for (SIT/UAT/Prod) and what’s the exact component/service name?")

    return "\n".join(lines)


def filter_chunks_by_page_ids(chunks_meta, page_ids_set):
    if not page_ids_set:
        return chunks_meta
    return [c for c in chunks_meta if c.get("page_id") in page_ids_set]


def find_last_user_index(messages):
    for i in range(len(messages) - 1, -1, -1):
        if messages[i]["role"] == "user":
            return i
    return None


def delete_messages_after(messages, idx):
    del messages[idx + 1 :]


