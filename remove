def build_assistant_reply(query: str, retrieved_top: list):
    qtype = classify_question(query)

    # Sentence candidates + fusion
    cands = extract_top_sentences_from_chunks(query, retrieved_top, max_candidates=120)
    fused = fuse_sentences(cands, max_groups=6, max_sentences_per_group=3)
    summaries = page_summaries(query, retrieved_top, top_pages=6, sentences_per_page=2)

    if not fused and not summaries:
        return (
            "I couldn’t find a strong match in the indexed docs for that. "
            "Try different keywords (e.g., component name, environment name, error code)."
        )

    # Make a short “direct answer”
    direct_bits = []
    for item in fused[:2]:
        direct_bits.append(item["text"])
    direct_answer = " ".join(direct_bits).strip()
    direct_answer = highlight_keywords(direct_answer, query)

    lines = []
    lines.append(f"**Answer (from the docs):**  \n{direct_answer}\n")

    # Style based on question type
    if qtype == "howto":
        lines.append("**Suggested steps:**")
        # Turn fused items into numbered steps
        step_no = 1
        for item in fused:
            txt = highlight_keywords(item["text"], query)
            # Keep steps short
            txt = txt[:300] + ("…" if len(txt) > 300 else "")
            if item.get("url") and item.get("title"):
                lines.append(f"{step_no}. {txt}  \n   <small>Source: <a href='{item['url']}' target='_blank'>{item['title']}</a></small>")
            else:
                lines.append(f"{step_no}. {txt}")
            step_no += 1
            if step_no > 6:
                break

    elif qtype == "troubleshoot":
        lines.append("**Likely causes / fixes (from the docs):**")
        for item in fused[:6]:
            txt = highlight_keywords(item["text"], query)
            if item.get("url") and item.get("title"):
                lines.append(f"- {txt}  \n  <small>Source: <a href='{item['url']}' target='_blank'>{item['title']}</a></small>")
            else:
                lines.append(f"- {txt}")

    elif qtype == "definition":
        lines.append("**Definition / explanation:**")
        for item in fused[:5]:
            txt = highlight_keywords(item["text"], query)
            if item.get("url") and item.get("title"):
                lines.append(f"- {txt}  \n  <small>Source: <a href='{item['url']}' target='_blank'>{item['title']}</a></small>")
            else:
                lines.append(f"- {txt}")

    else:
        lines.append("**Key points:**")
        for item in fused[:6]:
            txt = highlight_keywords(item["text"], query)
            if item.get("url") and item.get("title"):
                lines.append(f"- {txt}  \n  <small>Source: <a href='{item['url']}' target='_blank'>{item['title']}</a></small>")
            else:
                lines.append(f"- {txt}")

    # Navigation section
    if summaries:
        lines.append("\n**Best matching pages:**")
        for s in summaries[:6]:
            sm = highlight_keywords(s["summary"], query)
            if s.get("url"):
                lines.append(f"- <a href='{s['url']}' target='_blank'>{s['title']}</a>: {sm}")
            else:
                lines.append(f"- {s['title']}: {sm}")

    # A small assistant-like follow-up prompt (no LLM, just helpful)
    if qtype in ("howto", "troubleshoot"):
        lines.append("\n**Quick follow-up:**")
        lines.append("- Which environment is this for (SIT/UAT/Prod) and what’s the exact error text?")

    return "\n".join(lines)






retrieved_top = retrieved[:15]
