import random

def get_with_retries(url, *, params, auth, headers, timeout, verify, max_retries=8):
    """
    Retries on rate limiting (429) and transient errors (502/503/504).
    Honors Retry-After if provided. Uses exponential backoff + jitter otherwise.
    """
    attempt = 0
    while True:
        r = requests.get(
            url,
            params=params,
            auth=auth,
            headers=headers,
            timeout=timeout,
            verify=verify,
        )

        # Success
        if r.status_code < 400:
            return r

        # 400 is a real error (CQL etc.) -> do not retry
        if r.status_code == 400:
            raise RuntimeError(
                f"400 from Confluence. CQL was:\n{params.get('cql')}\n\nResponse:\n{r.text[:800]}"
            )

        # Retry-able: rate limit / transient gateway issues
        if r.status_code in (429, 502, 503, 504):
            attempt += 1
            if attempt > max_retries:
                raise RuntimeError(
                    f"Confluence request failed after {max_retries} retries "
                    f"(last status={r.status_code}). Response:\n{r.text[:500]}"
                )

            retry_after = r.headers.get("Retry-After")
            if retry_after:
                # Retry-After can be seconds
                try:
                    sleep_s = int(retry_after)
                except Exception:
                    sleep_s = 5
            else:
                # Exponential backoff with jitter: 1,2,4,8,... capped
                base = min(60, 2 ** (attempt - 1))
                sleep_s = base + random.uniform(0, 1.5)

            print(f"[THROTTLE] status={r.status_code} attempt={attempt}/{max_retries} sleeping={sleep_s:.1f}s")
            time.sleep(sleep_s)
            continue

        # Other errors: raise immediately
        r.raise_for_status()
