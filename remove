        if st.button("Clear Chat", use_container_width=True):
            st.session_state.messages = []
            st.session_state.pending_question = None
            st.session_state.active_page_ids = None
            st.session_state.last_answer_page_ids = []
            st.session_state.editing_last = False
            st.rerun()
    with btn2:
        if st.button("Reset Scope", use_container_width=True):
            st.session_state.active_page_ids = None
            st.session_state.last_answer_page_ids = []
            st.rerun()

    # Sync / Reindex expander (bottom-ish)
    with st.expander("Sync / Reindex (advanced)", expanded=not bool(st.session_state.bm25)):
        st.write("Pull Confluence pages → chunk → tokenize → BM25 index (local).")

        st.markdown("**Current CQL:**")
        st.code(cfg.get("cql", ""), language="sql")

        conf_user = st.text_input("Confluence user", key="conf_user")
        conf_pass = st.text_input("Confluence password", type="password", key="conf_pass")

        if st.button("Sync Now", disabled=st.session_state.syncing):
            st.session_state.syncing = True
            st.session_state.sync_msg = ""
            st.rerun()

        if st.session_state.syncing:
            with st.spinner("Syncing Confluence and building index..."):
                progress = st.progress(0)
                status = st.empty()

                if not conf_user or not conf_pass:
                    progress.progress(100)
                    st.session_state.sync_msg = "❌ Enter Confluence credentials."
                    st.session_state.syncing = False
                    st.rerun()

                pages = sync_confluence(cfg, conf_user, conf_pass)

                if not pages:
                    progress.progress(100)
                    st.session_state.sync_msg = "✅ No updated pages found. Index unchanged."
                    st.session_state.syncing = False
                    st.rerun()

                total_pages = len(pages)
                chunks_meta_new = []

                max_workers = min(16, (os.cpu_count() or 4))
                status.write(f"Parallel processing with {max_workers} workers...")

                with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as ex:
                    futures = {ex.submit(process_page_to_chunks, p, CHUNK_SIZE, OVERLAP): p for p in pages}

                    done = 0
                    for fut in concurrent.futures.as_completed(futures):
                        p = futures[fut]
                        try:
                            page_chunks = fut.result()
                            chunks_meta_new.extend(page_chunks)
                        except Exception as e:
                            status.write(f"⚠ Failed page: {p.get('title','')} — {e}")

                        done += 1
                        progress.progress(int(done / total_pages * 100))

                existing = load_chunks() or []
                changed_ids = {x["page_id"] for x in chunks_meta_new if x.get("page_id")}
                existing = [x for x in existing if x.get("page_id") not in changed_ids]
                combined = existing + chunks_meta_new

                st.session_state.chunks_meta = combined
                st.session_state.bm25 = build_bm25(combined)
                save_chunks(combined)

                progress.progress(100)
                st.session_state.sync_msg = (
                    f"✅ Sync complete. Updated {len(changed_ids)} pages. Total chunks: {len(combined)}."
                )
                st.session_state.syncing = False
                st.rerun()

        # Cache operations
        c1, c2 = st.columns(2)
        with c1:
            if st.button("Clear Cache", use_container_width=True):
                if os.path.exists(CHUNKS_PATH):
                    os.remove(CHUNKS_PATH)
                st.session_state.chunks_meta = None
                st.session_state.bm25 = None
                st.session_state.sync_msg = "✅ Cache cleared. Sync again."
                st.rerun()
        with c2:
            st.caption("Tip: initial sync can take time for large spaces.")


# -----------------------------
# Right panel: Chat + controls + scrollable chat history
# -----------------------------
with col2:
    st.subheader("Chat")

    # Controls in an expander to keep chat clean
    with st.expander("Controls (edit, scope)", expanded=True):
        # ---- Edit last question (Edit button UX) ----
        last_user_idx = find_last_user_index(st.session_state.messages)

        st.markdown("**Edit last question**")
        if last_user_idx is None:
            st.caption("No questions yet.")
        else:
            last_q = st.session_state.messages[last_user_idx]["content"]

            r1, r2 = st.columns([5, 1])
            with r1:
                st.markdown(f"<div class='small-label'><b>Last question:</b> {last_q}</div>", unsafe_allow_html=True)
            with r2:
                if st.button("Edit", use_container_width=True):
                    st.session_state.editing_last = True

            if st.session_state.editing_last:
                edited_q = st.text_area("Edit", value=last_q, key="edit_last_question")

                b1, b2, b3 = st.columns([2, 2, 2])
                with b1:
                    if st.button("Update & Regenerate", use_container_width=True):
                        st.session_state.messages[last_user_idx]["content"] = edited_q
                        delete_messages_after(st.session_state.messages, last_user_idx)
                        st.session_state.pending_question = edited_q
                        st.session_state.editing_last = False
                        st.rerun()
                with b2:
                    if st.button("Cancel edit", use_container_width=True):
                        st.session_state.editing_last = False
                        st.rerun()
                with b3:
                    if st.button("Reset scope to Global", use_container_width=True):
                        st.session_state.active_page_ids = None
                        st.session_state.last_answer_page_ids = []
                        st.session_state.editing_last = False
                        st.rerun()

        st.divider()

        # ---- Conversation scope ----
        st.markdown("**Conversation scope**")
        scope_mode = st.radio(
            "Search scope",
            ["Global (all docs)", "Follow-up only (last answer pages)"],
            horizontal=True,
            key="scope_mode_radio",
        )
        st.session_state.scope_mode = scope_mode

        if st.session_state.active_page_ids:
            st.caption(f"Scoped to {len(st.session_state.active_page_ids)} pages from last answer.")
        else:
            st.caption("Scoped to all indexed pages.")

    # ---- Scrollable chat history ----
    st.markdown('<div class="chat-scroll">', unsafe_allow_html=True)
    for m in st.session_state.messages:
        with st.chat_message(m["role"]):
            if m["role"] == "assistant":
                st.markdown(m["content"], unsafe_allow_html=True)
            else:
                st.markdown(m["content"])
    st.markdown("</div>", unsafe_allow_html=True)

    # ---- Chat input always at bottom ----
    prompt = st.chat_input("Ask about the docs…")

    # Decide what question to run: edited regen vs new input
    if st.session_state.pending_question:
        prompt_to_run = st.session_state.pending_question
        st.session_state.pending_question = None
    elif prompt:
        prompt_to_run = prompt
    else:
        prompt_to_run = None

    if prompt_to_run:
        # Add user message if it isn't already the last message
        if not (
            st.session_state.messages
            and st.session_state.messages[-1]["role"] == "user"
            and st.session_state.messages[-1]["content"] == prompt_to_run
        ):
            st.session_state.messages.append({"role": "user", "content": prompt_to_run})

        if not st.session_state.bm25 or not st.session_state.chunks_meta:
            st.session_state.messages.append(
                {"role": "assistant", "content": "I don’t have an index yet. Please run **Sync Now** first."}
            )
            st.rerun()

        # Apply scope (follow-up only)
        chunks_for_search = st.session_state.chunks_meta
        if st.session_state.scope_mode.startswith("Follow-up") and st.session_state.active_page_ids:
            chunks_for_search = filter_chunks_by_page_ids(chunks_for_search, st.session_state.active_page_ids)

        # Build scoped BM25 (fast for small scope)
        bm25_scoped = build_bm25(chunks_for_search)

        retrieved = search_bm25(
            prompt_to_run,
            bm25_scoped,
            chunks_for_search,
            top_k=TOP_K,
        )

        assistant_text = build_assistant_reply_page_first(prompt_to_run, retrieved)

        # Update scope from this answer (top 8 pages)
        new_scope = []
        seen = set()
        for r in retrieved[:25]:
            pid = r.get("page_id")
            if pid and pid not in seen:
                seen.add(pid)
                new_scope.append(pid)
            if len(new_scope) >= 8:
                break

        st.session_state.last_answer_page_ids = new_scope

        if st.session_state.scope_mode.startswith("Follow-up"):
            if new_scope:
                st.session_state.active_page_ids = set(new_scope)
        else:
            st.session_state.active_page_ids = None

        st.session_state.messages.append({"role": "assistant", "content": assistant_text})
        st.rerun()
